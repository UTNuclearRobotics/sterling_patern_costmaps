<launch>
  <arg name="model" default="$(env TURTLEBOT3_MODEL)" doc="model type [burger, waffle, waffle_pi]"/>
  <arg name="x_pos" default="-2.0"/>
  <arg name="y_pos" default="-0.5"/>
  <arg name="z_pos" default="0.0"/>
  <arg name="namespace" default="" doc="Namespace for this robot"/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find turtlebot3_gazebo)/worlds/turtlebot3_world.world"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="headless" value="false"/>
    <arg name="debug" value="false"/>
  </include>

  <arg name="robot_name" default="burger" />

  <group if="$(eval namespace != '')" ns="$(arg namespace)">
    <!-- Robot description -->
    <param name="robot_description"
           command="$(find xacro)/xacro --inorder $(find turtlebot3_description)/urdf/turtlebot3_$(arg model).urdf.xacro" />

    <!-- TurtleBot3 bringup (includes robot_state_publisher) -->
    <include file="$(find turtlebot3_bringup)/launch/turtlebot3_core.launch">
      <arg name="multi_robot_name" value="$(arg namespace)" />
    </include>

    <!-- Spawn robot in Gazebo -->
    <node pkg="gazebo_ros" type="spawn_model" name="spawn_urdf"
          args="-urdf -model $(arg robot_name) -x $(arg x_pos) -y $(arg y_pos) -z $(arg z_pos) -param robot_description" />

    <!-- Parameters -->
    <rosparam>
      odom_frame: odom
      map_frame: map
      base_frame: base_footprint
      scan_topic: scan
      mode: mapping
    </rosparam>
  </group>

  <group unless="$(eval namespace != '')">
    <!-- Robot description -->
    <param name="robot_description"
           command="$(find xacro)/xacro --inorder $(find turtlebot3_description)/urdf/turtlebot3_$(arg model).urdf.xacro" />

    <!-- TurtleBot3 bringup (includes robot_state_publisher) -->
    <include file="$(find turtlebot3_bringup)/launch/turtlebot3_core.launch" />

    <!-- Spawn robot in Gazebo -->
    <node pkg="gazebo_ros" type="spawn_model" name="spawn_urdf"
          args="-urdf -model $(arg robot_name) -x $(arg x_pos) -y $(arg y_pos) -z $(arg z_pos) -param robot_description" />

    <!-- Parameters -->
    <rosparam>
      odom_frame: odom
      map_frame: map
      base_frame: base_footprint
      scan_topic: scan
      mode: mapping
    </rosparam>
  </group>
</launch>
